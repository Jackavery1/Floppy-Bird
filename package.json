{
    "name": "floppy-bird",
    "version": "2.0.0",
    "description": "Floppy Bird — Phaser 3, PWA, scores locaux",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:tokens": "vite --open /tokens.html",
        "build": "node scripts/copy-phaser.mjs && vite build",
        "preview": "vite preview --port 8000",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ci": "playwright test --workers=1 --project=chromium-desktop --project=chromium-mobile-portrait --project=chromium-mobile-landscape --project=webkit-mobile-portrait --project=webkit-mobile-landscape --project=chromium-tablet-landscape",
        "test:e2e:smoke": "playwright test --workers=1 --project=chromium-desktop --project=chromium-mobile-portrait e2e/loading.spec.js e2e/offline.spec.js e2e/viewport-pwa.spec.js e2e/viewport.spec.js e2e/touchTargets.spec.js e2e/keyboard.spec.js e2e/gameplay-equity.spec.mjs e2e/visual-regression.spec.js e2e/visual-font.spec.js",
        "test:e2e:install": "playwright install chromium webkit",
        "lighthouse": "node scripts/lighthouse-ci.mjs",
        "lint": "eslint .",
        "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"e2e/**/*.js\" \"scripts/**/*.mjs\"",
        "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"e2e/**/*.js\" \"scripts/**/*.mjs\"",
        "icons": "node scripts/generate-icons.mjs",
        "icons:optimize": "node scripts/optimize-icons.mjs",
        "measure": "node scripts/measure-bundle.mjs",
        "clean": "node scripts/clean-artifacts.mjs",
        "cycles": "madge --circular --extensions js src/",
        "verify": "npm run lint && npm run format:check && npm test",
        "prepare": "node scripts/install-git-hooks.mjs"
    },
    "dependencies": {
        "@fontsource/press-start-2p": "^5.2.7",
        "phaser": "^3.80.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.49.1",
        "@vitest/coverage-v8": "^2.1.9",
        "chrome-launcher": "^1.1.2",
        "eslint": "^9.17.0",
        "globals": "^15.14.0",
        "lighthouse": "^12.3.0",
        "madge": "^8.0.0",
        "prettier": "^3.4.2",
        "sharp": "^0.33.5",
        "vite": "^5.4.11",
        "vite-plugin-pwa": "^0.21.1",
        "vitest": "^2.1.6"
    }
}
