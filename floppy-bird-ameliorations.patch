diff --git a/tests/skins.test.js b/tests/skins.test.js
new file mode 100644
index 0000000..4fbb4cf
--- /dev/null
+++ b/tests/skins.test.js
@@ -0,0 +1,77 @@
+import { describe, it, expect } from 'vitest';
+import {
+    SKIN_IDS,
+    SKINS,
+    getSkin,
+    listUnlockedSkins,
+    nextUnlockedSkin,
+} from '../src/skins.js';
+
+function baseCtx(overrides = {}) {
+    return {
+        bestScoreAny: 0,
+        bestHardcoreScore: 0,
+        bestEasyScore: 0,
+        bestNormalScore: 0,
+        bestHardScore: 0,
+        ...overrides,
+    };
+}
+
+describe('skins', () => {
+    it('expose 8 skins uniques, classique toujours débloqué', () => {
+        expect(SKIN_IDS).toHaveLength(8);
+        expect(new Set(SKIN_IDS).size).toBe(8);
+        expect(SKINS.classic.unlock(baseCtx())).toBe(true);
+    });
+
+    it('getSkin retombe sur classique pour un id inconnu', () => {
+        expect(getSkin('does-not-exist').id).toBe('classic');
+        expect(getSkin(undefined).id).toBe('classic');
+    });
+
+    it('ruby/ocean/forest gardent leurs seuils historiques', () => {
+        expect(SKINS.ruby.unlock(baseCtx({ bestScoreAny: 9 }))).toBe(false);
+        expect(SKINS.ruby.unlock(baseCtx({ bestScoreAny: 10 }))).toBe(true);
+        expect(SKINS.ocean.unlock(baseCtx({ bestScoreAny: 20 }))).toBe(true);
+        expect(SKINS.forest.unlock(baseCtx({ bestHardcoreScore: 5 }))).toBe(true);
+    });
+
+    it('armure se débloque à 15 en hardcore (au-delà de forêt)', () => {
+        expect(SKINS.armure.unlock(baseCtx({ bestHardcoreScore: 14 }))).toBe(false);
+        expect(SKINS.armure.unlock(baseCtx({ bestHardcoreScore: 15 }))).toBe(true);
+    });
+
+    it('mushu exige 15+ dans les 3 difficultés', () => {
+        expect(SKINS.mushu.unlock(baseCtx({ bestEasyScore: 15, bestNormalScore: 15, bestHardScore: 10 }))).toBe(false);
+        expect(SKINS.mushu.unlock(baseCtx({ bestEasyScore: 15, bestNormalScore: 15, bestHardScore: 15 }))).toBe(true);
+    });
+
+    it('fantôme se débloque à 30 (au-delà d’océan)', () => {
+        expect(SKINS.fantome.unlock(baseCtx({ bestScoreAny: 29 }))).toBe(false);
+        expect(SKINS.fantome.unlock(baseCtx({ bestScoreAny: 30 }))).toBe(true);
+    });
+
+    it('néon exige que tous les autres skins soient débloqués', () => {
+        const almost = baseCtx({
+            bestScoreAny: 30, bestHardcoreScore: 15,
+            bestEasyScore: 15, bestNormalScore: 15, bestHardScore: 14,
+        });
+        expect(SKINS.neon.unlock(almost)).toBe(false);
+
+        const everything = baseCtx({
+            bestScoreAny: 30, bestHardcoreScore: 15,
+            bestEasyScore: 15, bestNormalScore: 15, bestHardScore: 15,
+        });
+        expect(SKINS.neon.unlock(everything)).toBe(true);
+        expect(listUnlockedSkins(everything)).toHaveLength(8);
+    });
+
+    it('nextUnlockedSkin boucle uniquement sur les skins débloqués', () => {
+        const ctx = baseCtx({ bestScoreAny: 10 }); // classic + ruby
+        expect(listUnlockedSkins(ctx)).toEqual(['classic', 'ruby']);
+        expect(nextUnlockedSkin('classic', ctx)).toBe('ruby');
+        expect(nextUnlockedSkin('ruby', ctx)).toBe('classic');
+        expect(nextUnlockedSkin('forest', ctx)).toBe('classic');
+    });
+});
